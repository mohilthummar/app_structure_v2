# Form Validation and Input Handling

## Validation Mixin

### Using ValidationMixin
All controllers that handle forms should use the [ValidationMixin](mdc:lib/core/utils/validation_mixin.dart):

```dart
class SignInController extends BaseViewController with ValidationMixin {
  GlobalKey<FormState> formKey = GlobalKey<FormState>();
  TextEditingController emailController = TextEditingController();
  TextEditingController passwordController = TextEditingController();
  
  // Use mixin validators
  String? emailValidator(String? value) => emailValidator(value);
  String? passwordValidator(String? value) => passwordValidator(value);
}
```

### Available Validators
The `ValidationMixin` provides these validators:

- `emailValidator(String? email)` - Email format validation
- `passwordValidator(String? password)` - Strong password validation
- `newPasswordValidator(String? password)` - New password validation
- `confirmPasswordValidator(String? value, String password)` - Password confirmation
- `confirmPasswordValidatorForForgotPassword(String? value, String newPassword)` - Forgot password confirmation
- `phoneValidator(String? value, int phoneLength)` - Phone number validation
- `nameValidator(String? value)` - Name validation
- `addressValidator(String? value)` - Address validation

## Form Structure

### Basic Form Setup
```dart
class FeatureController extends BaseViewController with ValidationMixin {
  // Form key for validation
  GlobalKey<FormState> formKey = GlobalKey<FormState>();
  
  // Text controllers
  TextEditingController nameController = TextEditingController();
  TextEditingController emailController = TextEditingController();
  TextEditingController phoneController = TextEditingController();
  
  // Form submission
  Future<void> onSubmit() async {
    if (formKey.currentState?.validate() ?? false) {
      // Form is valid, proceed with submission
      await _submitForm();
    }
  }
  
  // Cleanup
  @override
  void onClose() {
    nameController.dispose();
    emailController.dispose();
    phoneController.dispose();
    super.onClose();
  }
}
```

### Form Widget Implementation
```dart
class FeatureView extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return GetBuilder<FeatureController>(
      builder: (controller) => Scaffold(
        body: Form(
          key: controller.formKey,
          child: Column(
            children: [
              TextFormField(
                controller: controller.nameController,
                decoration: InputDecoration(
                  labelText: 'Name',
                  hintText: 'Enter your name',
                ),
                validator: controller.nameValidator,
              ),
              TextFormField(
                controller: controller.emailController,
                decoration: InputDecoration(
                  labelText: 'Email',
                  hintText: 'Enter your email',
                ),
                keyboardType: TextInputType.emailAddress,
                validator: controller.emailValidator,
              ),
              TextFormField(
                controller: controller.phoneController,
                decoration: InputDecoration(
                  labelText: 'Phone',
                  hintText: 'Enter your phone number',
                ),
                keyboardType: TextInputType.phone,
                validator: (value) => controller.phoneValidator(value, 10),
              ),
              ElevatedButton(
                onPressed: controller.onSubmit,
                child: Text('Submit'),
              ),
            ],
          ),
        ),
      ),
    );
  }
}
```

