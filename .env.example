# ============================================
# APP CONFIGURATION — TEMPLATE
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git. Only .env.example is committed.
#
# Environment is selected in main.dart via:
#   AppEnvironment.setEnvironment(EnvironmentType.development);
# ============================================

# -- App --
APP_NAME=App Name

# -- Base URLs (per environment) --
BASE_URL_LOCAL=http://192.168.1.100:3000
BASE_URL_DEV=https://api-dev.example.com
BASE_URL_STAGING=https://api-staging.example.com
BASE_URL_PROD=https://api.example.com

# -- Firebase --
# FIREBASE_API_KEY_DEV=
# FIREBASE_API_KEY_STAGING=
# FIREBASE_API_KEY_PROD=
# FIREBASE_PROJECT_ID=

# -- Payment Keys --
# RAZORPAY_KEY_DEV=
# RAZORPAY_KEY_STAGING=
# RAZORPAY_KEY_PROD=

# -- Feature Flags --
ENABLE_LOGGING=false
ENABLE_CRASHLYTICS=false

## API ENDPOINTS  --------------------------------------------------------------

# -- Auth Endpoints --
EP_SIGN_UP=/auth/signup
EP_SIGN_IN=/auth/signin
EP_VALIDATE_SIGN_UP_OTP=/auth/validate-signup-otp
EP_VALIDATE_SIGN_IN_OTP=/auth/validate-signin-otp
EP_RESEND_OTP=/auth/resend-otp

# -- Common Endpoints --
EP_NEW_FEATURE_DETAILS=/new-feature/details
